# Traefik 配置
TRAEFIK_EMAIL=277739025@qq.com
TRAEFIK_NETWORK=traefik-public
TRAEFIK_LOG_LEVEL=INFO
TRAEFIK_HTTP_REDIRECT=false

# MongoDB 配置
# MONGO_ENABLED: true 表示启用 MongoDB，false 表示禁用（会自动停止现有容器）
MONGO_ENABLED=true
MONGO_VERSION=6.0
MONGO_PORT=27017
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=your_secure_password_here
MONGO_MEMORY_LIMIT=512m

# 数据目录
TRAEFIK_DIR=/Users/yuanjin/个人/个人开发/server-env/opt/traefik
PRODUCTS_DIR=/Users/yuanjin/个人/个人开发/server-env/opt/products
MONGO_DIR=/Users/yuanjin/个人/个人开发/server-env/opt/mongodb
POSTGRES_DIR=/Users/yuanjin/个人/个人开发/server-env/opt/postgres

# PostgreSQL 配置
# POSTGRES_ENABLED: true 表示启用 PostgreSQL，false 表示禁用（会自动停止现有容器）
POSTGRES_ENABLED=true
POSTGRES_VERSION=16
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_MEMORY_LIMIT=512m