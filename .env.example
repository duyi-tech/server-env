# Traefik 配置
TRAEFIK_EMAIL=your_email  # letsencrypt 证书申请邮箱
TRAEFIK_NETWORK=traefik-public  # traefik 网络名称
TRAEFIK_LOG_LEVEL=INFO  # traefik 日志级别
TRAEFIK_HTTP_REDIRECT=false  # 是否开启 http 重定向到 https

# MongoDB 配置
# MONGO_ENABLED: true 表示启用 MongoDB，false 表示禁用（会自动停止现有容器）
MONGO_ENABLED=true  # 是否启用 MongoDB
MONGO_VERSION=6.0  # MongoDB 版本
MONGO_PORT=27017  # MongoDB 端口
MONGO_ROOT_USERNAME=root  # MongoDB 根用户名
MONGO_ROOT_PASSWORD=your_secure_password_here  # MongoDB 根密码
MONGO_MEMORY_LIMIT=512m  # MongoDB 内存限制

# PostgreSQL 配置
# POSTGRES_ENABLED: true 表示启用 PostgreSQL，false 表示禁用（会自动停止现有容器）
POSTGRES_ENABLED=true  # 是否启用 PostgreSQL
POSTGRES_VERSION=16  # PostgreSQL 版本
POSTGRES_USER=postgres  # PostgreSQL 用户名
POSTGRES_PASSWORD=your_secure_password_here  # PostgreSQL 密码
POSTGRES_MEMORY_LIMIT=512m  # PostgreSQL 内存限制

# 数据目录
TRAEFIK_DIR=/opt/shared/traefik  # traefik 数据目录
PRODUCTS_DIR=/opt/shared/products  # 产品数据目录
MONGO_DIR=/opt/shared/mongodb  # MongoDB 数据目录
POSTGRES_DIR=/opt/shared/postgres  # PostgreSQL 数据目录
MYSQL_DIR=/opt/shared/mysql  # MySQL 数据目录
