# Traefik 配置
TRAEFIK_EMAIL=your_email  
TRAEFIK_NETWORK=traefik-public 
TRAEFIK_LOG_LEVEL=INFO  
TRAEFIK_HTTP_REDIRECT=false  

# MongoDB 配置
# MONGO_ENABLED: true 表示启用 MongoDB，false 表示禁用（会自动停止现有容器）
MONGO_ENABLED=false  
MONGO_VERSION=6.0  
MONGO_PORT=27017 
MONGO_ROOT_USERNAME=root  
MONGO_ROOT_PASSWORD=your_secure_password_here  
MONGO_MEMORY_LIMIT=512m  

# PostgreSQL 配置
# POSTGRES_ENABLED: true 表示启用 PostgreSQL，false 表示禁用（会自动停止现有容器）
POSTGRES_ENABLED=false  
POSTGRES_VERSION=16  
POSTGRES_USER=postgres 
POSTGRES_PASSWORD=your_secure_password_here  
POSTGRES_MEMORY_LIMIT=512m  

# MySQL 配置
# MYSQL_ENABLED: true 表示启用 MySQL，false 表示禁用（会自动停止现有容器）
MYSQL_ENABLED=false
MYSQL_VERSION=8.0
MYSQL_ROOT_PASSWORD=your_secure_password_here
MYSQL_MEMORY_LIMIT=512m

# 数据目录
TRAEFIK_DIR=/opt/shared/traefik  
MONGO_DIR=/opt/shared/mongodb  
POSTGRES_DIR=/opt/shared/postgres  
MYSQL_DIR=/opt/shared/mysql  


PRODUCTS_DIR=/opt/products  
